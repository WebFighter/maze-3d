{
  "$schema": "https://unpkg.com/release-it@17/schema/release-it.json",
  "git": {
    "tagName": "v${version}",
    "commitMessage": "chore(release): v${version}",
    "requireCommits": true
  },
  "github": false,
  "npm": false,
  "hooks": {
    "after:release": "echo Successfully released ${name} v${version} to ${repo.repository}."
  }
}
